{
  "name": "localops-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:all": "npm run dev:server & npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "server:start": "tsx src/server/index.ts",
    "lint": "svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:api": "vitest run --config vitest.api.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/scaffold/bootstrap-login-smoke.spec.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dexie": "^3.2.7",
    "express": "^5.2.1",
    "svelte": "^5.28.2",
    "svelte-spa-router": "^4.0.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@testing-library/svelte": "^5.2.8",
    "@tsconfig/svelte": "^5.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.5.2",
    "@types/supertest": "^7.2.0",
    "fake-indexeddb": "^6.2.2",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "supertest": "^7.2.2",
    "svelte-check": "^4.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
