{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "rootDir": ".",
    "esModuleInterop": true
  },
  "include": ["src/server/**/*.ts", "src/shared/types/**/*.ts"]
}
